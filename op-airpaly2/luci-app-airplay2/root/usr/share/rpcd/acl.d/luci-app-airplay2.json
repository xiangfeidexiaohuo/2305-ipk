{
	"luci-app-airplay2": {
		"description": "Grant UCI access for luci-app-airplay2",
		"read": {
			"file": {
				"/bin/cat": [ "exec" ],
				"/proc/asound/cards": [ "read" ],
				"/usr/bin/bluealsa-aplay": [ "exec", "stat" ]
			},
			"ubus": {
				"service": [ "list" ]
			},
			"uci": [ "airplay2" ]
		},
		"write": {
			"uci": [ "airplay2" ]
		}
	}
}
